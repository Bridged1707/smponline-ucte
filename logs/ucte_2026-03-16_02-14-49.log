[UCTE] raw ws message: {"event":"auctionComplete","timestamp":1773645819098,"data":{"item":{"type":"PINK_SHULKER_BOX","quantity":1,"name":"The Lusty Argonian Maid Box Set","snbt":"{\"minecraft:container\":[{item:{components:{\"minecraft:custom_name\":\"The Lusty Argonian Maid v.I\",\"minecraft:written_book_content\":{author:\"ThatFlyingWaffle\",generation:2,pages:[{raw:\"\\n\\n\\n\\n        The Lusty  \\n    Argonian Maid v.I\\n\\n     Crassius Curio\"},{raw:\"Act IV, Scene III, continued\\n\\nLifts-Her-Tail\\nCertainly not, kind sir! I am here but to clean your chambers.\\n\\nCrantius Colto\\nIs that all you have come here for, little one? My chambers?\"},{raw:\"Lifts-Her-Tail\\nI have no idea what it is you imply, master. I am but a poor Argonian maid.\\n\\nCrantius Colto\\nSo you are, my dumpling. And a good one at that. Such strong legs and shapely tail.\"},{raw:\"Lifts-Her-Tail\\nYou embarrass me, sir!\\n\\nCrantius Colto\\nFear not. You are safe here with me.\\n\\nLifts-Her-Tail\\nI must finish my cleaning, sir. The mistress will have my head if I do not!\"},{raw:\"Crantius Colto\\nCleaning, eh? I have something for you. Here, polish my spear.\\n\\nLifts-Her-Tail\\nBut it is huge! It could take me all night!\\n\\nCrantius Colto\\nPlenty of time, my sweet. Plenty of time.\\n\"},{raw:\"\\n\\n\\n     END OF ACT IV, \\n        SCENE III\"}],resolved:1b,title:{raw:\"The Maid 1\"}}},count:1,id:\"minecraft:written_book\"},slot:0},{item:{components:{\"minecraft:custom_name\":\"The Lusty Argonian Maid v.II\",\"minecraft:written_book_content\":{author:\"ThatFlyingWaffle\",generation:2,pages:[{raw:\"\\n\\n\\n\\n        The Lusty  \\n   Argonian Maid v.II\\n\\n     Crassius Curio\"},{raw:\"ACT VII, SCENE II, CONTINUED\\n\\nLifts-Her-Tail\\nMy goodness, that’s quite a loaf! But how ever shall it fit my oven?\\n\\nCrantius Colto\\nThis loaf isn’t ready for baking, my sweet. It has yet to rise.\"},{raw:\"Lifts-Her-Tail\\nIf only we could hurry that along. How would I accomplish such a task?\\n\\nCrantius Colto\\nOh, my foolish little Argonian maid, you must use your hands.\\n\\nLifts-Her-Tail\\nYou wish me to kneed the loaf? Here?\"},{raw:\"Crantius Colto\\nOf course.\\n\\nLifts-Her-Tail\\nBut what if the mistress catches me? Your loaf was meant to satisfy her appetite.\\n\\n\"},{raw:\"Crantius Colto\\nDon’t fret, my delicate flower. I’ll satisfy the mistress’s cravings later.\\n\\nLifts-Her-Tail\\nVery well, but I’m afraid my oven isn’t hot enough. It could take hours!\"},{raw:\"Crantius Colto\\nPlenty of time, my sweet. Plenty of time.\\n\\n\"},{raw:\"\\n\\n\\n     END OF ACT IIV, \\n         SCENE II\"}],resolved:1b,title:{raw:\"The Maid 2\"}}},count:1,id:\"minecraft:written_book\"},slot:1},{item:{count:1,id:\"minecraft:chiseled_bookshelf\"},slot:2}],\"minecraft:custom_name\":\"The Lusty Argonian Maid Box Set\"}","childItems":[{"type":"WRITTEN_BOOK","quantity":1,"name":"The Lusty Argonian Maid v.I","snbt":"{\"minecraft:custom_name\":\"The Lusty Argonian Maid v.I\",\"minecraft:written_book_content\":{author:\"ThatFlyingWaffle\",generation:2,pages:[{raw:\"\\n\\n\\n\\n        The Lusty  \\n    Argonian Maid v.I\\n\\n     Crassius Curio\"},{raw:\"Act IV, Scene III, continued\\n\\nLifts-Her-Tail\\nCertainly not, kind sir! I am here but to clean your chambers.\\n\\nCrantius Colto\\nIs that all you have come here for, little one? My chambers?\"},{raw:\"Lifts-Her-Tail\\nI have no idea what it is you imply, master. I am but a poor Argonian maid.\\n\\nCrantius Colto\\nSo you are, my dumpling. And a good one at that. Such strong legs and shapely tail.\"},{raw:\"Lifts-Her-Tail\\nYou embarrass me, sir!\\n\\nCrantius Colto\\nFear not. You are safe here with me.\\n\\nLifts-Her-Tail\\nI must finish my cleaning, sir. The mistress will have my head if I do not!\"},{raw:\"Crantius Colto\\nCleaning, eh? I have something for you. Here, polish my spear.\\n\\nLifts-Her-Tail\\nBut it is huge! It could take me all night!\\n\\nCrantius Colto\\nPlenty of time, my sweet. Plenty of time.\\n\"},{raw:\"\\n\\n\\n     END OF ACT IV, \\n        SCENE III\"}],resolved:1b,title:{raw:\"The Maid 1\"}}}"},{"type":"WRITTEN_BOOK","quantity":1,"name":"The Lusty Argonian Maid v.II","snbt":"{\"minecraft:custom_name\":\"The Lusty Argonian Maid v.II\",\"minecraft:written_book_content\":{author:\"ThatFlyingWaffle\",generation:2,pages:[{raw:\"\\n\\n\\n\\n        The Lusty  \\n   Argonian Maid v.II\\n\\n     Crassius Curio\"},{raw:\"ACT VII, SCENE II, CONTINUED\\n\\nLifts-Her-Tail\\nMy goodness, that’s quite a loaf! But how ever shall it fit my oven?\\n\\nCrantius Colto\\nThis loaf isn’t ready for baking, my sweet. It has yet to rise.\"},{raw:\"Lifts-Her-Tail\\nIf only we could hurry that along. How would I accomplish such a task?\\n\\nCrantius Colto\\nOh, my foolish little Argonian maid, you must use your hands.\\n\\nLifts-Her-Tail\\nYou wish me to kneed the loaf? Here?\"},{raw:\"Crantius Colto\\nOf course.\\n\\nLifts-Her-Tail\\nBut what if the mistress catches me? Your loaf was meant to satisfy her appetite.\\n\\n\"},{raw:\"Crantius Colto\\nDon’t fret, my delicate flower. I’ll satisfy the mistress’s cravings later.\\n\\nLifts-Her-Tail\\nVery well, but I’m afraid my oven isn’t hot enough. It could take hours!\"},{raw:\"Crantius Colto\\nPlenty of time, my sweet. Plenty of time.\\n\\n\"},{raw:\"\\n\\n\\n     END OF ACT IIV, \\n         SCENE II\"}],resolved:1b,title:{raw:\"The Maid 2\"}}}"},{"type":"CHISELED_BOOKSHELF","quantity":1,"name":"Chiseled Bookshelf","snbt":"{}"},null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null]},"amount":1,"finalBid":15.0}}
